{
  "name": "lopaka",
  "version": "0.45.0",
  "description": "Embedded graphics editor with code builder",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest --mode test --run",
    "test-dev": "vitest --mode test",
    "test-report": "vitest --coverage.enabled true --run",
    "build": "vitepress build pages && vite build",
    "build:exe": "pnpm build && electron-builder --win portable",
    "docs:dev": "vitepress dev pages",
    "docs:build": "vitepress build pages",
    "docs:preview": "vitepress preview pages",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com"
  },
  "keywords": [
    "embedded",
    "editor",
    "graphics",
    "canvas",
    "arduino",
    "u8g2",
    "flipperzero"
  ],
  "author": "sbrin",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com"
  },
  "homepage": "https://github.com",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@vitejs/plugin-basic-ssl": "^2.0.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^3.1.2",
    "@vitest/ui": "^3.1.2",
    "@vue/test-utils": "^2.4.1",
    "autoprefixer": "^10.4.19",
    "daisyui": "^4.11.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "husky": "^9.0.11",
    "jsdom": "^26.1.0",
    "prettier": "^3.0.3",
    "probe-image-size": "^7.2.3",
    "tailwindcss": "^3.4.3",
    "vite": "^6.3.3",
    "vitepress": "^1.3.0",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "@heroicons/vue": "^2.1.5",
    "@supabase/supabase-js": "^2.44.2",
    "@types/dom-serial": "^1.0.4",
    "ace-builds": "^1.32.6",
    "base64-arraybuffer": "^1.0.2",
    "gifuct-js": "^2.1.2",
    "pako": "^2.1.0",
    "posthog-js": "^1.160.3",
    "pug": "^3.0.2",
    "truetype2gfx": "*",
    "typescript": "^5.2.2",
    "vue": "^3.5.29",
    "vue-router": "^4.4.0",
    "vue3-ace-editor": "^2.2.4",
    "vuedraggable": "^4.1.0"
  },
  "packageManager": "pnpm@10.30.3",
  "build": {
    "appId": "com.lopaka.app",
    "productName": "Lopaka",
    "files": [
      "dist/**/*",
      "main.cjs"
    ],
    "directories": {
      "output": "release"
    }
  }
}
